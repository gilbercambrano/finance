# Copia este archivo a ".env" y reemplaza los valores antes de levantar docker-compose.
# NUNCA subas el archivo ".env" real a un repositorio de código.

# --- PostgreSQL ---
POSTGRES_USER=finanzas_user
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA_LARGA_Y_UNICA
POSTGRES_DB=finanzas

# --- API ---
# Genera una clave segura con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTA_CLAVE_SECRETA

# En producción con HTTPS configurado, deja esto en true (cookies solo por HTTPS).
# Si todavía no tienes HTTPS, ponlo en false temporalmente para poder iniciar sesión.
COOKIE_SECURE=true

# Número de workers de Gunicorn (2-4 según los núcleos del servidor)
WEB_CONCURRENCY=2
